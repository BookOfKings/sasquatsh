{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "playwright test --project=chromium --workers=2",
    "test:all": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --project=chromium --workers=1 --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:light": "playwright test --project=chromium --workers=2 --grep-invert='Authenticated'",
    "test:auth": "playwright test --project=chromium --workers=2 --grep='Authenticated'",
    "test:cleanup": "powershell -Command \"Get-Process | Where-Object {$_.Path -like '*playwright*' -or $_.MainWindowTitle -eq ''} | Where-Object {$_.ProcessName -match 'chrom'} | Stop-Process -Force -ErrorAction SilentlyContinue\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/postcss": "^4.2.1",
    "firebase": "^12.9.0",
    "sass": "^1.94.1",
    "vite-plugin-vuetify": "^2.1.2",
    "vue": "^3.5.24",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^24.10.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vue-tsc": "^3.1.3"
  }
}
